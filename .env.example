# ----------------------------------------------------------------------------
# PullMD environment configuration
#
# `.env` is OPTIONAL — the default `docker-compose.yml` works without it
# (port-published on http://localhost:3000). Copy this file to `.env` only
# if you want to override defaults or run the Traefik variant.
# ----------------------------------------------------------------------------

# Host port exposed by the default compose file (mapped to container port 3000).
# PORT=3000

# Public hostname (without scheme). REQUIRED for `docker-compose.traefik.yml`,
# unused by the default compose. Drives Traefik routing.
# HOST_DOMAIN=pullmd.example.com

# Public URL of this PullMD instance — embedded in the help page and the
# downloadable pullmd skill zip. Defaults to `http://localhost:${PORT}`
# (default compose) or `https://${HOST_DOMAIN}` (Traefik compose).
# Override only if you serve behind a different reverse proxy that rewrites
# the public origin.
# PUBLIC_URL=https://pullmd.example.com

# SQLite cache file path. The Docker images create `/data` and the bundled
# compose files mount `./data:/data` and set `CACHE_DB=/data/cache.db`.
# For local `npm start`, the default is `./data/cache.db` (relative to cwd).
# Override only if you want the database somewhere else.
# CACHE_DB=/data/cache.db

# Hide the global recent-conversions list and archive view on shared instances.
# When `true`, GET /api/history and GET /api/archive return 403 and the
# frontend hides the "Recent" section and archive nav. /s/:id share links
# keep working so anyone with a known ID still gets their markdown. Use on
# multi-tenant VPS / office deployments where you don't want every visitor
# to see what other users have fetched. Default: false.
# DISABLE_PUBLIC_HISTORY=false

# ----------------------------------------------------------------------------
# Authentication (new in v2.0)
# ----------------------------------------------------------------------------

# Auth mode. One of:
#   disabled       Default. No auth, everything open. Existing v1.x behavior.
#   single-admin   One user, credentials from PULLMD_ADMIN_EMAIL / _PASSWORD
#                  below. No self-signup. For personal homelab.
#   multi-user     Self-signup at /signup, login at /login, per-user data.
#
# When you switch from `disabled` to a non-disabled mode, the first startup
# bootstraps an admin user and backfills all existing cached conversions to
# that admin. See MIGRATION.md.
# PULLMD_AUTH_MODE=disabled

# Bootstrap credentials for the first admin user. Required on first startup
# when PULLMD_AUTH_MODE != disabled. After the admin exists, changing these
# does not change the password — use `node scripts/admin.js reset-password`.
# PULLMD_ADMIN_EMAIL=admin@example.com
# PULLMD_ADMIN_PASSWORD=change-me-please

# Legacy bearer token (single-admin mode only, deprecated; slated for removal
# in a future major release).
# When set, requests with `Authorization: Bearer <token>` resolve to the admin
# user. Useful for keeping pre-2.0 reverse-proxy setups working during migration.
# Generate a fresh API key in /settings instead for new clients.
# PULLMD_AUTH_TOKEN=

# ----------------------------------------------------------------------------
# OAuth 2.1 (new in v2.3)
# ----------------------------------------------------------------------------

# JWT signing secret for OAuth access tokens. REQUIRED to enable the OAuth
# Authorization Code flow used by claude.ai Web Connector. Must be at least
# 32 characters. Keep separate from session/cookie secrets — never reuse.
# Generate with:  openssl rand -hex 32
# OAUTH_JWT_SECRET=

# Note: PUBLIC_URL must also be set when OAuth is enabled (used as the JWT
# issuer + audience and in the discovery metadata).

# ----------------------------------------------------------------------------
# Reddit API credentials (optional)
# Without these, PullMD uses Reddit's public JSON endpoints (~60 req/min,
# no NSFW or quarantined access). With OAuth credentials, PullMD authenticates
# via client_credentials and uses oauth.reddit.com (100 req/min).
# Create a "script" app at https://www.reddit.com/prefs/apps
# ----------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Reddit requires a unique User-Agent.
# Format: "platform:appname:version (by u/yourname)"
# Default if empty: "PullMD/1.0 (URL-to-Markdown service)"
REDDIT_USER_AGENT=

# ----------------------------------------------------------------------------
# Outbound User-Agent rotation (web fetch path, not Reddit)
# ----------------------------------------------------------------------------

# Pin a single User-Agent for every outbound web request. Disables rotation
# entirely. Useful for CI determinism or when you've found one specific UA
# that works for your target sites. Leave empty to use the rotating pool.
# PULLMD_USER_AGENT=

# URL of a JSON feed with current real-world UAs. Default: a curated feed
# maintained by @WinFuture23, refreshed every 48h. Set to an empty string
# to disable live refresh and rely solely on the built-in seed pool. Set to
# any other URL to use your own feed (must match the same JSON shape:
# { "user_agents": [{ "ua": "...", "device_type": "computer", ... }, ...] }).
# PULLMD_UA_FEED_URL=https://raw.githubusercontent.com/WinFuture23/real-world-user-agents/refs/heads/main/user-agents.json

# ----------------------------------------------------------------------------
# Site recipes
# ----------------------------------------------------------------------------

# Path to a user recipes JSON file (merged over the built-in defaults, see
# site-recipes.default.json for the format). Without this, a file at
# data/site-recipes.json is picked up automatically when running from the
# repo directory. In Docker, place the file in ./data (mounted at /data)
# and point this at the container path:
# PULLMD_SITE_RECIPES=/data/site-recipes.json

# ----------------------------------------------------------------------------
# Sidecar URLs
# The default docker-compose.yml wires all three sidecars automatically.
# Override here only if you run them on custom addresses. Each sidecar is
# optional - PullMD degrades gracefully when its URL is unset:
#   TRAFILATURA_URL unset -> Readability becomes the only HTML extractor
#                            (no second opinion for the quality pick).
#   PLAYWRIGHT_URL unset  -> no JS-rendering fallback; JS-heavy pages may
#                            come back thin.
#   MARKITDOWN_URL unset  -> document conversion (PDF/Office/EPUB/ZIP/CSV/
#                            JSON/XML) returns 502, AND the YouTube tier is
#                            disabled (its /youtube endpoint is derived from
#                            this URL).
# ----------------------------------------------------------------------------

# TRAFILATURA_URL=http://trafilatura:8001/extract
# PLAYWRIGHT_URL=http://playwright:8002/render
# MARKITDOWN_URL=http://markitdown:8003/convert

# Media tier (opt-in): image captioning (vision) + audio transcription (STT).
# OpenAI-compatible per-modality providers; point _BASE_URL at any compatible
# server (cloud or local). A modality is enabled only when its key is set.
#
# Common _BASE_URL values (unset = OpenAI):
#   OpenAI       https://api.openai.com/v1                                (vision + STT)
#   Claude       https://api.anthropic.com/v1                             (vision only)
#   Mistral      https://api.mistral.ai/v1                                (vision + STT)
#   Groq         https://api.groq.com/openai/v1                           (vision + STT)
#   Gemini       https://generativelanguage.googleapis.com/v1beta/openai  (vision only)
#   OpenRouter   https://openrouter.ai/api/v1                             (vision only)
#   Ollama       http://localhost:11434/v1                                (vision only, local)
# (STT needs the provider to offer the /audio/transcriptions endpoint.)
#
# Example (OpenAI): PULLMD_VISION_MODEL=gpt-4o-mini, PULLMD_STT_MODEL=whisper-1
PULLMD_VISION_API_KEY=
PULLMD_VISION_BASE_URL=
PULLMD_VISION_MODEL=
PULLMD_STT_API_KEY=
PULLMD_STT_BASE_URL=
PULLMD_STT_MODEL=
# Shared fallback for both modalities (per-modality vars win when set):
PULLMD_LLM_API_KEY=
PULLMD_LLM_BASE_URL=

# High-quality PDF tier (opt-in, paid): route PDFs through an OCR provider that
# preserves tables. Reference provider: Mistral OCR (mistral-ocr-latest, ~$0.002/page).
# Enabled per request with ?pdf=ocr (or a recipe fetch.pdf: ocr default); default
# PDF handling stays the free markitdown path. Point _BASE_URL at any compatible
# endpoint (incl. a self-hosted engine - see README).
# Requires its own key (does not use the shared PULLMD_LLM_* fallback - the OCR
# provider is usually a different endpoint).
# _BASE_URL unset = Mistral (https://api.mistral.ai/v1); _MODEL unset = mistral-ocr-latest.
PULLMD_PDF_OCR_API_KEY=
PULLMD_PDF_OCR_BASE_URL=
PULLMD_PDF_OCR_MODEL=

# ----------------------------------------------------------------------------
# Output format
# ----------------------------------------------------------------------------

# v2 compatibility switch for the v3 breaking change (see MIGRATION.md):
# set to true to restore the legacy inline source header in the body
# (# Title + **domain** · date + url; for Reddit posts the
# **r/sub** · u/user · N ↑ meta line). Default (unset or empty): clean body -
# just the H1 title; source/date live in the frontmatter instead.
# PULLMD_SOURCE_HEADER=true

# Allowlist of frontmatter fields to emit, comma-separated. Unset or empty =
# all fields. Useful to trim tokens for agent consumers. Note that frontmatter
# itself is opt-in per request (?frontmatter=true, MCP: frontmatter).
# Known fields (see the frontmatter table in README.md): title, url, source,
# fetched, quality, author, published, modified, description, language, image,
# site, extractor_reason, share_id, share_url, subreddit, upvotes,
# duration, views, image_size,
# audio_seconds, pdf_pages, llm_model, llm_tokens, llm_prompt_tokens,
# llm_completion_tokens, cached, refreshed, age_ms.
# Unknown names are ignored with a startup warning; if no valid name remains,
# all fields are emitted (safe fallback, never a crash).
# PULLMD_FRONTMATTER_FIELDS=title,url,source,fetched

# --- MarkItDown YouTube tier (opt-in; no API key required) ---
# Set MARKITDOWN_YOUTUBE=true on the pullmd service to enable YouTube URL routing
# through the markitdown sidecar (transcript + title + description extraction).
MARKITDOWN_YOUTUBE=
# On the markitdown sidecar service. These set default behaviour; each can also
# be overridden per request via ?yt_timecodes= / ?yt_chunk= query params:
# links | plain | none
MARKITDOWN_YT_TIMECODES=links
# transcript block size in seconds; 0 = per original snippet
MARKITDOWN_YT_CHUNK=30
# preferred transcript languages, comma-separated (e.g. de,en);
# empty = first available language
# MARKITDOWN_YT_LANGS=
# optional http(s) proxy; datacenter IPs are often rate-limited
MARKITDOWN_YT_PROXY=

# Document-conversion sandboxing (markitdown sidecar). Each conversion runs in a
# disposable child process so a decompression bomb / pathological file can't pin
# CPU or OOM the server.
# Per-conversion wall-clock timeout in seconds; 0 disables.
MARKITDOWN_CONVERT_TIMEOUT=60
# Container-level hard memory bound for the sidecar (docker mem_limit).
MARKITDOWN_MEM_LIMIT=1g
# Optional per-conversion address-space cap in MB; 0 = rely on MARKITDOWN_MEM_LIMIT.
MARKITDOWN_MEM_LIMIT_MB=0
